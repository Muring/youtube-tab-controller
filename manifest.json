{
  "manifest_version": 3,
  "name": "YouTube Tab Controller",
  "version": "2.1",
  "description": "유튜브 탭의 재생/일시정지를 툴바에서 바로 제어합니다.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "YouTube Controller"
  }
}
